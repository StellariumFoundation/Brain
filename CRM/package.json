{
  "name": "brain-crm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch server.ts",
    "build": "bun build ./src/main.tsx --outfile=./public/index.js --bundle && bun build ./server.ts --outfile=./dist/server.js --target=node",
    "start": "bun ./dist/server.js",
    "clean": "rm -rf dist public/index.js crm.db crm_fallback.json"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "dotenv": "^17.2.3",
    "hono": "^4.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "@types/bun": "latest"
  }
}
